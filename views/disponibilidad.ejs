<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disponibilidad: <%= nombre %> | CBTis 234</title>
    <link rel="stylesheet" href="/css/main.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
   
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        .grid-disp { 
            display: grid; 
            grid-template-columns: 120px repeat(5, 1fr); 
            gap: 8px; 
            background: #f4f7f6; 
            padding: 20px; 
            border-radius: 12px;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }
        
        .header-grid { 
            font-weight: bold; 
            text-align: center; 
            background: var(--cbtis-azul); 
            color: white; 
            padding: 12px; 
            border-radius: 8px;
            font-size: 0.85rem;
            text-transform: uppercase;
        }
        
        .cell-disp { 
            background: white;
            border: 1px solid var(--gris-borde); 
            padding: 10px; 
            text-align: center; 
            border-radius: 8px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .cell-disp:hover {
            border-color: var(--cbtis-celeste);
            background-color: #f0f7ff;
        }

        /* Efecto visual para celdas marcadas */
        .cell-disp:has(input:checked) {
            background-color: #e3f2fd;
            border-color: var(--cbtis-celeste);
            box-shadow: 0 0 8px rgba(0, 153, 204, 0.2);
        }

        .hora-col {
            font-weight: 700;
            background: #ebedef;
            color: var(--cbtis-azul);
            font-size: 0.85rem;
            cursor: default;
        }

        .checkbox-custom {
            width: 22px;
            height: 22px;
            cursor: pointer;
            accent-color: var(--cbtis-azul);
        }

        .btn-footer {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        .btn-regresar {
            background: #95a5a6;
            color: white;
            text-decoration: none;
            padding: 15px;
            border-radius: 10px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1;
            transition: 0.3s;
        }

        .btn-regresar:hover {
            background: #7f8c8d;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="sidebar">
            <h2>Administrador</h2>
            <ul>
                <li><a href="/dashboard"><i class="bi bi-house-door"></i> Inicio</a></li>
                <li><a href="/docentes"><i class="bi bi-arrow-left-circle"></i> Volver a Docentes</a></li>
                <hr style="border: 0.5px solid rgba(255,255,255,0.1); margin: 10px 0;">
                <li><a href="#" onclick="confirmarSalida(event)" style="color: #ff7675;"><i class="bi bi-box-arrow-left"></i> Cerrar Sesión</a></li>
            </ul>
        </div>

        <div class="content-page">
            <div class="main-container" style="max-width: 1000px;">
                
                <h1 class="titulo">Gestión de Disponibilidad</h1>
                
                <div class="card-uniforme">
                    <div style="text-align: center; margin-bottom: 25px;">
                        <span style="background: var(--cbtis-azul); color: white; padding: 5px 15px; border-radius: 20px; font-size: 0.9rem;">
                            Docente: <strong><%= nombre %></strong>
                        </span>
                    </div>

                    <form action="/guardar-disponibilidad" method="POST" id="formDisponibilidad">
                        <input type="hidden" name="id_docente" value="<%= id %>">
                        
                        <div class="grid-disp">
                            <div class="header-grid">Horario</div>
                            <div class="header-grid">Lunes</div>
                            <div class="header-grid">Martes</div>
                            <div class="header-grid">Miércoles</div>
                            <div class="header-grid">Jueves</div>
                            <div class="header-grid">Viernes</div>

                            <% bloques.forEach(b => { %> 
                                <div class="cell-disp hora-col"><%= b %></div> 
                                
                                <% ['Lunes','Martes','Miercoles','Jueves','Viernes'].forEach(dia => { %> 
                                    <div class="cell-disp" onclick="this.querySelector('input').click(); event.stopPropagation();">
                                        <% 
                                            const estaMarcado = horariosGuardados.some(h => 
                                                h.dia === dia && 
                                                h.hora_inicio === b.split('-')[0] + ":00" 
                                            );
                                        %>
                                        <input type="checkbox" name="disponibilidad[]" 
                                               value="<%= dia %>|<%= b %>" 
                                               class="checkbox-custom"
                                               onclick="event.stopPropagation();"
                                               <%= estaMarcado ? 'checked' : '' %>>
                                    </div>
                                <% }) %>
                            <% }) %>
                        </div>

                        <div class="btn-footer">
                            <a href="/docentes" class="btn-regresar">
                                <i class="bi bi-x-circle-fill me-2"></i> Cancelar
                            </a>
                            
                            <button type="submit" class="btn-primario" style="flex: 2;" onclick="confirmarGuardado(event)">
                                <i class="bi bi-cloud-check-fill me-2"></i> Guardar Jornada Laboral
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function confirmarGuardado(event) {
            event.preventDefault();
            Swal.fire({
                title: '¿Actualizar disponibilidad?',
                text: "Se registrarán estos horarios como el tiempo activo del docente en el plantel",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#003366',
                cancelButtonColor: '#95a5a6',
                confirmButtonText: 'Sí, guardar cambios',
                cancelButtonText: 'Seguir revisando'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Guardando...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });
                    document.getElementById('formDisponibilidad').submit();
                }
            });
        }

        function confirmarSalida(event) {
            event.preventDefault();
            Swal.fire({
                title: '¿Cerrar sesión?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#003366',
                cancelButtonColor: '#ff7675',
                confirmButtonText: 'Salir',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) window.location.href = "/logout";
            });
        }
    </script>
</body>
</html>