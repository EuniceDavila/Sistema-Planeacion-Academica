<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acceso al Sistema | CBTis 234</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="login-page"> 

    <div class="login-card">
        <div class="login-header">
            <i class="bi bi-person-circle" style="font-size: 3rem; color: #003366;"></i>
            <h2>CBTis 234</h2>
            <p>Sistema de Planeación Académica</p>
        </div>

        <form action="/login" method="POST" class="login-form">
            <div class="input-group">
                <label><i class="bi bi-person"></i> Usuario</label>
                <input type="text" name="usuario" placeholder="Ingresa tu usuario" required>
            </div>

            <div class="input-group">
                <label><i class="bi bi-lock"></i> Contraseña</label>
                <input type="password" name="contrasena" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn-primario btn-block">
                <i class="bi bi-box-arrow-in-right"></i> Ingresar al Sistema
            </button>
        </form>
    </div>

</body>
</html>

