<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel de Incidencias | CBTis 234</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <div class="sidebar">
            <h2>Administrador</h2>
            <ul>
                <li><a href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                <li><a href="/incidencias"><i class="bi bi-exclamation-octagon"></i> Incidencias</a></li>
                <hr style="opacity: 0.2;">
                <li><a href="/logout"><i class="bi bi-box-arrow-left"></i> Salir</a></li>
            </ul>
        </div>

        <div class="content-page">
            <div class="main-container">
                <h1 class="titulo">Incidencias por Resolver</h1>
                <div class="card-uniforme">
                    <table class="tabla-general">
                        <thead>
                            <tr>
                                <th>Docente</th>
                                <th>Materia</th>
                                <th>Problema Reportado</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (incidencias.length > 0) { %>
                                <% incidencias.forEach(inc => { %>
                                    <tr>
                                        <td><strong><%= inc.docente %></strong></td>
                                        <td><%= inc.materia %></td>
                                        <td style="color: #d63031;">"<%= inc.descripcion %>"</td>
                                        <td>
                                            <a href="/horarios/editar/<%= inc.id_horario %>?incidencia=<%= inc.id_incidencia %>" class="btn-accion">
                                                <i class="bi bi-pencil-square"></i> Corregir Horario
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="4">No hay problemas pendientes. ¡Todo en orden!</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>