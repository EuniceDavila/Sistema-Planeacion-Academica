<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Incidencias | CBTis 234</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="container">
        <div class="sidebar">
            <h2>Administrador</h2>
             <ul>
                <li><a href="/dashboard"><i class="bi bi-house-door"></i> Inicio</a></li>
                <li><a href="/docentes"><i class="bi bi-person-badge"></i> Docentes</a></li>
                <li><a href="/materias"><i class="bi bi-book"></i> Materias</a></li>
                <li><a href="/grupos"><i class="bi bi-people"></i> Grupos</a></li>
                <li><a href="/aulas"><i class="bi bi-building"></i> Aulas</a></li>
                <li><a href="/horarios"><i class="bi bi-calendar3"></i> Horarios</a></li>
                <li><a href="/asignar-materias"><i class="bi bi-journal-check"></i> Asignar Materias</a></li>
                <li><a href="/crear-horario"><i class="bi bi-clock"></i> Programar Clase</a></li>
                <li><a href="/incidencias"><i class="bi bi-bell"></i> Incidencias Pendientes</a></li>
                <hr style="border: 0.5px solid rgba(255,255,255,0.1); margin: 10px 0;">
                <li><a href="#" onclick="confirmarSalida(event)" style="color: #ff7675;"><i class="bi bi-box-arrow-left"></i> Cerrar Sesión</a></li>
            </ul>
        </div>

        <div class="content-page">
            <div class="main-container">
                <h1 class="titulo">Reportes de Docentes</h1>
                
                <div class="card-uniforme">
                    <table class="tabla-general">
                       <thead>
                            <tr>
                                <th>Docente</th>
                                <th>Clase Reportada</th>
                                <th>Motivo del Error</th>
                                <th>Estado</th> 
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (incidencias.length > 0) { %>
                                <% incidencias.forEach(incidencia => { %>
                                    <tr>
                                        <td><strong><%= incidencia.docente %></strong></td>
                                        <td>
                                            <%= incidencia.materia %>
                                            <span class="texto-secundario">
                                                <i class="bi bi-calendar-event"></i> <%= incidencia.dia %> — <i class="bi bi-clock"></i> <%= incidencia.hora_inicio.substring(0, 5) %> hs
                                            </span>
                                        </td>
                                        <td><%= incidencia.descripcion %></td>
                                        <td>
                                            <% if (incidencia.estado === 'pendiente') { %>
                                                <span class="badge-pendiente">Pendiente</span>
                                            <% } else if (incidencia.estado === 'rechazado') { %>
                                                <span class="badge-pendiente" style="background-color: #fce4e4; color: #c0392b;">Rechazado</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="acciones-flex">
                                                <% if (incidencia.estado === 'pendiente') { %>
                                                    <button type="button" class="btn-tabla btn-exito btn-resolver" 
                                                            data-id="<%= incidencia.id_incidencia %>" 
                                                            data-horario="<%= incidencia.id_horario %>">
                                                        <i class="bi bi-check-circle"></i> Resolver
                                                    </button>

                                                    <button type="button" class="btn-tabla btn-peligro btn-rechazar" 
                                                            data-id="<%= incidencia.id_incidencia %>">
                                                        <i class="bi bi-x-circle"></i> Declinar Cambio
                                                    </button>
                                                <% } else { %>
                                                    <span style="color: #7f8c8d; font-size: 0.85rem; font-style: italic;">Sin acciones</span>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" style="color: #7f8c8d; padding: 40px 20px;">
                                        <i class="bi bi-clipboard-check" style="font-size: 2rem; display: block; margin-bottom: 10px; color: var(--cbtis-celeste);"></i>
                                        No hay reportes de incidencias pendientes.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <form id="form-incidencias-global" method="POST" style="display: none;"></form>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const formGlobal = document.getElementById('form-incidencias-global');
            
            document.querySelectorAll('.btn-resolver').forEach(boton => {
                boton.addEventListener('click', (e) => {
                    const idIncidencia = e.currentTarget.getAttribute('data-id');
                    const idHorario = e.currentTarget.getAttribute('data-horario');
                    
                    Swal.fire({
                        title: '¿Resolver incidencia?',
                        text: "Te redirigiremos al formulario para modificar el horario en conflicto.",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#2ecc71',
                        cancelButtonColor: '#7f8c8d',
                        confirmButtonText: 'Ir a modificar',
                        cancelButtonText: 'Cancelar'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = `/horarios/editar/${idHorario}?incidencia=${idIncidencia}`;
                        }
                    });
                });
            });

            document.querySelectorAll('.btn-rechazar').forEach(boton => {
                boton.addEventListener('click', (e) => {
                    const id = e.currentTarget.getAttribute('data-id');
                    Swal.fire({
                        title: '¿Declinar cambio sugerido?',
                        text: "La incidencia se cerrará y el horario original se mantendrá activo en el sistema.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#e74c3c',
                        cancelButtonColor: '#7f8c8d',
                        confirmButtonText: 'Sí, rechazar reporte',
                        cancelButtonText: 'Cancelar'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            formGlobal.action = `/incidencias/${id}/rechazar`;
                            formGlobal.submit();
                        }
                    });
                });
            });
        });

        function confirmarSalida(e) {
            e.preventDefault();
            Swal.fire({
                title: '¿Cerrar Sesión?',
                text: "Saldrás de la cuenta del Administrador.",
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#003366',
                cancelButtonColor: '#7f8c8d',
                confirmButtonText: 'Salir',
                cancelButtonText: 'Permanecer'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/logout";
                }
            });
        }
    </script>
</body>
</html>